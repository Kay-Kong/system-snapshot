#!/usr/bin/env bash
CONFIG_FILE='/etc/system-snapshot/system-snapshot.conf'

set -euo pipefail

# Logging helpers
info() {
	echo "[Info] $*" >&2
}

fatal() {
	echo "[ERROR] $*" >&2
	exit 1
}

[[ -r $CONFIG_FILE ]] || fatal "Missing config: $CONFIG_FILE"
. "$CONFIG_FILE"

MIN_BACKUP_INTERVAL=$((MIN_BACKUP_INTERVAL_DAYS * 24 * 3600))

require_safe_paths() {
	# Guard rails against a bad config causing rsync --delete to target the
	# wrong place. Keep these intentionally strict.
	[[ -n ${BASE:-} ]] || fatal "BASE not set in $CONFIG_FILE"
	[[ -n ${MIRROR:-} ]] || fatal "MIRROR not set in $CONFIG_FILE"
	[[ $BASE == /var/backups/local/system ]] || fatal "Unexpected BASE: $BASE"
	[[ $MIRROR == "$BASE/mirror" ]] || fatal "Unexpected MIRROR: $MIRROR"
	[[ $MIRROR != '/' ]] || fatal 'Refusing to use / as mirror'
	[[ $MIRROR != '/var/backups' ]] || fatal 'Refusing to use /var/backups as mirror'
}

last_success_epoch() {
	if [[ -f $LAST_SUCCESS_FILE ]]; then
		stat -c %Y "$LAST_SUCCESS_FILE"
	else
		echo 0
	fi
}

is_due() {
	# The timer fires twice daily but a real backup only runs once per
	# MIN_BACKUP_INTERVAL_DAYS. A failed run leaves LAST_SUCCESS_FILE stale,
	# so the next timer firing (~12h later) retries automatically.
	local now last
	now="$(date +%s)"
	last="$(last_success_epoch)"
	((now - last >= MIN_BACKUP_INTERVAL))
}

create_layout() {
	# The rsync destination should be a Btrfs subvolume so btrbk can snapshot it.
	if [[ -e $MIRROR ]]; then
		btrfs subvolume show "$MIRROR" >/dev/null 2>&1 ||
			fatal "$MIRROR exists but is not a Btrfs subvolume"
	else
		info "Creating Btrfs subvolume: $MIRROR"
		btrfs subvolume create "$MIRROR"
	fi

	mkdir -p "$STATE_DIR" "$LIVE_METADATA_DIR" "$BASE" "$SNAPSHOTS"

	chmod 700 "$STATE_DIR" "$LIVE_METADATA_DIR" "$BASE" "$MIRROR" "$SNAPSHOTS"
}

write_metadata() {
	# Recovery notes — small command outputs captured at backup time. Written
	# under STATE_DIR on the live root so the rsync system pass mirrors them
	# and btrbk's snapshot freezes a per-snapshot copy.

	# Kernel.
	uname -a >"$LIVE_METADATA_DIR/kernel.uname.txt" || true

	# Packages — dpkg covers .deb; snap and flatpak are separate ecosystems
	# that aren't reflected in dpkg state.
	dpkg-query -W -f='${binary:Package}\t${Version}\n' \
		>"$LIVE_METADATA_DIR/packages.all.txt" || true
	apt-mark showmanual \
		>"$LIVE_METADATA_DIR/packages.manual.txt" || true
	if command -v flatpak >/dev/null; then
		flatpak list --columns=application,version,branch,origin \
			>"$LIVE_METADATA_DIR/packages.flatpak.txt" || true
	fi
	if command -v snap >/dev/null; then
		snap list \
			>"$LIVE_METADATA_DIR/packages.snap.txt" || true
	fi

	# Services.
	systemctl list-unit-files --state=enabled \
		>"$LIVE_METADATA_DIR/services.enabled.txt" || true

	# Storage.
	blkid >"$LIVE_METADATA_DIR/storage.blkid.txt" || true
	findmnt >"$LIVE_METADATA_DIR/storage.findmnt.txt" || true
	lsblk -f >"$LIVE_METADATA_DIR/storage.lsblk.txt" || true

	# Users and groups — NSS-resolved view picks up LDAP/AD/SSSD sources that
	# aren't visible in /etc/passwd alone.
	getent group >"$LIVE_METADATA_DIR/users.group.txt" || true
	getent passwd >"$LIVE_METADATA_DIR/users.passwd.txt" || true
}

run_rsync_system() {
	info "Starting rsync mirror: / -> $MIRROR/"
	local rc=0
	rsync \
		--info=del1,progress2,stats2 \
		--checksum \
		--archive \
		--hard-links \
		--acls \
		--xattrs \
		--one-file-system \
		--delete-delay \
		--delete-excluded \
		--numeric-ids \
		--exclude-from="$RSYNC_EXCLUDE_FILE" \
		--human-readable \
		/ "$MIRROR/" 1>&2 || rc=$?
	# exit 24 is "some files vanished before transfer,"  benign on a live root.
	((rc == 0 || rc == 24)) || return $rc
}

run_btrbk() {
	info 'Running btrbk snapshot/prune'
	btrbk -c "$BTRBK_CONFIG_FILE" run 1>&2
}

main() {
	local ignore_cadence=0

	if (($# > 1)); then
		fatal "Too many arguments: $*"
	fi

	case ${1:-} in
	--now) ignore_cadence=1 ;;
	--init | '') ;;
	*) fatal "Unknown argument: $1" ;;
	esac

	# Avoid overlapping runs if the timer fires while a previous backup is still
	# active. The lock disappears automatically on reboot because it is in /run.
	exec 9>"$LOCK"
	flock -n 9 || exit 0

	require_safe_paths

	findmnt -rn --mountpoint /var/backups >/dev/null 2>&1 ||
		fatal '/var/backups is not mounted'

	findmnt -rn -t btrfs --mountpoint /var/backups >/dev/null 2>&1 ||
		fatal '/var/backups is not a Btrfs mount'

	create_layout

	if [[ ${1:-} == '--init' ]]; then
		info 'Initialized layout only'
		exit 0
	fi

	if ((ignore_cadence == 0)) && ! is_due; then
		info "Not due---last successful backup was less than ${MIN_BACKUP_INTERVAL_DAYS} days ago. Pass \`--now\` to run anyway."
		exit 0
	fi

	write_metadata
	run_rsync_system
	run_btrbk

	date --iso-8601=seconds >"$LAST_SUCCESS_FILE"

	info 'Backup completed successfully'
}

main "$@"
