#!/usr/bin/env bash
CONFIG='/etc/system-snapshot/system-snapshot.rc'

set -euo pipefail

exit_hooks=()
on_exit() {
	exit_hooks=("$1" "${exit_hooks[@]}")
	trap run_exit_hooks EXIT
}

run_exit_hooks() {
	local status=$? hook

	trap - EXIT
	set +e
	for hook in "${exit_hooks[@]}"; do
		"$hook"
	done
	exit "$status"
}

info() {
	printf '[INFO] %s\n' "$*" >&2
}

fatal() {
	printf '[ERROR] %s\n' "$*" >&2
	exit 1
}

load_config() {
	[[ -r $CONFIG ]] || fatal "Missing config: $CONFIG"
	. "$CONFIG"
	LOCK=${LOCK:-'/run/system-snapshot.lock'}
}

is_due() {
	local now="$(date +%s)" last=0

	if [[ -f $LAST_SUCCESS ]]; then
		last="$(stat -c %Y "$LAST_SUCCESS")"
	fi

	((now - last >= $((MIN_INTERVAL_DAYS * 24 * 3600))))
}

check_config() {
	[[ ${MIN_INTERVAL_DAYS:-} =~ ^[1-9][0-9]*$ ]] ||
		fatal "MIN_INTERVAL_DAYS must be a positive integer: ${MIN_INTERVAL_DAYS:-unset}"

	local name value
	for name in \
		MIRROR_MNT BACKUP_MNT SNAPSHOT_DIR \
		STATE_DIR LAST_SUCCESS METADATA_DIR \
		LOCK BTRBK_CONF RSYNC_EXCLUDE; do
		value=${!name:-}
		[[ -n $value ]] || fatal "$name not set in $CONFIG"
		[[ $value == /* ]] || fatal "$name must be absolute: $value"
		[[ $value != '/' ]] || fatal "$name cannot be /"
		[[ $value != *'..'* ]] || fatal "$name cannot contain '..': $value"
	done
	[[ $MIRROR_MNT != "$BACKUP_MNT" ]] || fatal "MIRROR_MNT cannot equal BACKUP_MNT"
	[[ $SNAPSHOT_DIR == "$BACKUP_MNT"/* ]] ||
		fatal "SNAPSHOT_DIR must be under BACKUP_MNT: $SNAPSHOT_DIR"
}

cleanup_lock() {
	rm -f "$LOCK"
}

acquire_lock() {
	exec 9>"$LOCK"
	if ! flock -n 9; then
		info 'Another instance is running; exiting'
		exit 0
	fi
	on_exit cleanup_lock
}

cleanup_mirror() {
	umount -l "$MIRROR_MNT" >/dev/null 2>&1 || true
}

check_mounts() {
	findmnt -rn -t btrfs --mountpoint "$BACKUP_MNT" >/dev/null 2>&1 ||
		fatal "$BACKUP_MNT is not mounted"

	if ! findmnt -rn --mountpoint "$MIRROR_MNT" >/dev/null 2>&1; then
		mkdir -p "$MIRROR_MNT"
		chmod 700 "$MIRROR_MNT"

		info "Mounting $MIRROR_MNT"

		mount "$MIRROR_MNT" || fatal "Failed to mount $MIRROR_MNT"
		on_exit cleanup_mirror
	fi
	btrfs subvolume show "$MIRROR_MNT" >/dev/null 2>&1 ||
		fatal "$MIRROR_MNT is not a Btrfs subvolume"
}

create_dirs() {
	mkdir -p "$STATE_DIR" "$METADATA_DIR" "$SNAPSHOT_DIR"
	chmod 700 "$STATE_DIR" "$METADATA_DIR" "$SNAPSHOT_DIR"
}

metadata_kernel() {
	uname -a
}

metadata_packages_all() {
	dpkg-query -W -f='${binary:Package}\t${Version}\n'
}

metadata_packages_manual() {
	apt-mark showmanual
}

metadata_packages_flatpak() {
	flatpak list --columns=application,version,branch,origin
}

metadata_packages_snap() {
	snap list
}

metadata_services_enabled() {
	systemctl list-unit-files --state=enabled
}

metadata_storage_blkid() {
	blkid
}

metadata_storage_findmnt() {
	findmnt
}

metadata_storage_lsblk() {
	lsblk -f
}

metadata_users_group() {
	getent group
}

metadata_users_passwd() {
	getent passwd
}

write_metadata() {
	local cmd file i jobs=(
		metadata_kernel kernel.uname.txt
		metadata_packages_all packages.all.txt
		metadata_packages_manual packages.manual.txt
		metadata_packages_flatpak packages.flatpak.txt
		metadata_packages_snap packages.snap.txt
		metadata_services_enabled services.enabled.txt
		metadata_storage_blkid storage.blkid.txt
		metadata_storage_findmnt storage.findmnt.txt
		metadata_storage_lsblk storage.lsblk.txt
		metadata_users_group users.group.txt
		metadata_users_passwd users.passwd.txt
	)

	for ((i = 0; i < ${#jobs[@]}; i += 2)); do
		cmd=${jobs[i]}
		file="$METADATA_DIR/${jobs[i + 1]}"
		"$cmd" >"$file" || rm -f -- "$file"
	done
}

run_rsync() {
	info "Starting rsync mirror: / -> $MIRROR_MNT/"
	local rc=0
	rsync \
		--info=del1,progress2,stats2 \
		--checksum \
		--archive \
		--hard-links \
		--acls \
		--xattrs \
		--one-file-system \
		--delete-delay \
		--delete-excluded \
		--numeric-ids \
		--exclude-from="$RSYNC_EXCLUDE" \
		--human-readable \
		/ "$MIRROR_MNT/" 1>&2 || rc=$?
	# exit 24 is "some files vanished before transfer,"  benign on a live root.
	((rc == 0 || rc == 24)) || return $rc
}

run_btrbk() {
	info 'Running btrbk snapshot/prune'
	local conf='/run/system-snapshot.btrbk.conf'

	cp --force -- "$BTRBK_CONF" "$conf"
	cat >>"$conf" <<-BTRBK_CONF

		subvolume '$MIRROR_MNT'
			snapshot_create onchange
			snapshot_dir '$SNAPSHOT_DIR'
			snapshot_name system
	BTRBK_CONF
	btrbk -c "$conf" run 1>&2
}

main() {
	(($# <= 1)) || fatal "Too many arguments: $*"

	local ignore_cadence=0
	case ${1:-} in
	--now) ignore_cadence=1 ;;
	--init | '') ;;
	*) fatal "Unknown argument: $1" ;;
	esac

	load_config
	check_config

	if ((ignore_cadence == 0)) && ! is_due; then
		info "Not due---last successful backup was less than ${MIN_INTERVAL_DAYS} days ago. Pass \`--now\` to run anyway."
		exit 0
	fi

	acquire_lock
	check_mounts
	create_dirs

	if [[ ${1:-} == '--init' ]]; then
		info 'Initialized layout only'
		exit 0
	fi

	write_metadata
	run_rsync
	run_btrbk

	date --iso-8601=seconds >"$LAST_SUCCESS"

	info 'Backup completed successfully'
}

main "$@"
