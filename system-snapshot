#!/usr/bin/env bash
CONFIG='/etc/system-snapshot/system-snapshot.rc'

set -euo pipefail

exit_hooks=()
on_exit() {
	exit_hooks=("$1" "${exit_hooks[@]}")
	trap run_exit_hooks EXIT
}

run_exit_hooks() {
	local status=$? hook

	trap - EXIT
	set +e
	for hook in "${exit_hooks[@]}"; do
		"$hook"
	done
	exit "$status"
}

info() {
	printf '[INFO]  %s\n' "$*" >&2
}

fatal() {
	printf '[ERROR] %s\n' "$*" >&2
	exit 1
}

load_config() {
	[[ -r $CONFIG ]] || fatal "Missing config: $CONFIG"
	. "$CONFIG"
}

check_config() {
	[[ ${MIN_INTERVAL_DAYS:-} =~ ^[1-9][0-9]*$ ]] ||
		fatal "MIN_INTERVAL_DAYS must be a positive integer: ${MIN_INTERVAL_DAYS:-unset}"

	local name value path_type
	for name in \
		STORAGE_MNT \
		MIRROR_SUBVOL \
		STATE_DIR LAST_SUCCESS METADATA_DIR SNAPSHOT_DIR \
		BTRBK_CONF RSYNC_EXCLUDE; do
		value=${!name:-}
		[[ -n $value ]] || fatal "$name not set in $CONFIG"

		[[ $value != '/' ]] || fatal "$name cannot be /"
		[[ $value != *'..'* ]] || fatal "$name cannot contain '..': $value"
		case $name in
		MIRROR_SUBVOL | SNAPSHOT_DIR)
			path_type='relative'
			[[ $value != /* ]]
			;;
		*)
			path_type='absolute'
			[[ $value == /* ]]
			;;
		esac || fatal "$name must be $path_type: $value"
	done
	[[ $MIRROR_SUBVOL == @* ]] ||
		fatal "MIRROR_SUBVOL should not omit the leading @: $MIRROR_SUBVOL"
	[[ $SNAPSHOT_DIR != "$MIRROR_SUBVOL" ]] ||
		fatal "SNAPSHOT_DIR cannot equal MIRROR_SUBVOL: $SNAPSHOT_DIR"
	[[ $SNAPSHOT_DIR != "$MIRROR_SUBVOL"/* ]] ||
		fatal "SNAPSHOT_DIR cannot be under MIRROR_SUBVOL: $SNAPSHOT_DIR"
	[[ ${SNAPSHOT_NAME:-} != *'/'* ]] ||
		fatal "SNAPSHOT_NAME cannot contain '/': $SNAPSHOT_NAME"
	[[ ${SNAPSHOT_NAME:-} != *'..'* ]] ||
		fatal "SNAPSHOT_NAME cannot contain '..': $SNAPSHOT_NAME"
	if [[ -n ${SNAPSHOT_NAME:-} && ! $SNAPSHOT_NAME =~ ^[A-Za-z0-9_-]+$ ]]; then
		fatal "SNAPSHOT_NAME may only contain letters, numbers, '_' and '-': $SNAPSHOT_NAME"
	fi

	rsync --dry-run --exclude-from="$RSYNC_EXCLUDE" --files-from=/dev/null / / >/dev/null
}

is_due() {
	local last=0 now="$(date +%s)"

	if [[ -f $LAST_SUCCESS ]]; then
		last="$(stat -c %Y "$LAST_SUCCESS")"
	fi

	((now - last >= $((MIN_INTERVAL_DAYS * 24 * 3600))))
}

release_lock() {
	rm -f "$LOCK"
	info "Released lock $LOCK"
}

acquire_lock() {
	LOCK='/run/system-snapshot.lock'
	info "Acquiring lock $LOCK"

	exec 9>"$LOCK"
	if ! flock -n 9; then
		info 'Another instance is running; exiting'
		exit 0
	fi
	on_exit release_lock
}

default_snapshot_name() {
	local name=$(hostname 2>/dev/null || true)
	name=${name%%.*}
	name=${name//[^A-Za-z0-9_-]/-}
	name=${name#"${name%%[!-]*}"}
	name=${name%"${name##*[!-]}"}
	[[ -n $name ]] || name='localhost'
	printf '%s\n' "$name"
}

unmount_storage() {
	umount -l "$STORAGE_MNT" >/dev/null 2>&1 || true
	info "Unmounted $STORAGE_MNT"
}

mount_storage() {
	info "Mounting $STORAGE_MNT"

	install -m 700 -d "$STORAGE_MNT"
	mount "$STORAGE_MNT" || fatal "Failed to mount $STORAGE_MNT"
	on_exit unmount_storage
}

check_mounts() {
	local mirror_dir="$STORAGE_MNT/$MIRROR_SUBVOL" \
		snapshot_dir="$STORAGE_MNT/$SNAPSHOT_DIR" \
		btrbk_conf='/run/system-snapshot.btrbk.conf' \
		snapshot_name="${SNAPSHOT_NAME:-$(default_snapshot_name)}"

	findmnt -rn --mountpoint "$STORAGE_MNT" >/dev/null 2>&1 || mount_storage

	for dir in "$STORAGE_MNT" "$mirror_dir"; do
		btrfs subvolume show "$dir" >/dev/null 2>&1 ||
			fatal "$dir is not a Btrfs subvolume"
	done

	install -m 700 -d "$snapshot_dir"
	cp --force -- "$BTRBK_CONF" "$btrbk_conf"
	cat >>"$btrbk_conf" <<-BTRBK_CONF

		volume $STORAGE_MNT
			subvolume $MIRROR_SUBVOL
				snapshot_dir $SNAPSHOT_DIR
				snapshot_name $snapshot_name
	BTRBK_CONF
	BTRBK_CONF=$btrbk_conf

	btrbk --quiet -c "$BTRBK_CONF" dryrun 1>&2
}

metadata_kernel() {
	uname -a
}

metadata_packages_all() {
	dpkg-query -W -f='${binary:Package}\t${Version}\n'
}

metadata_packages_manual() {
	apt-mark showmanual
}

metadata_packages_flatpak() {
	flatpak list --columns=application,version,branch,origin
}

metadata_packages_snap() {
	snap list
}

metadata_services_enabled() {
	systemctl list-unit-files --state=enabled
}

metadata_storage_blkid() {
	blkid
}

metadata_storage_findmnt() {
	findmnt
}

metadata_storage_lsblk() {
	lsblk -f
}

metadata_users_group() {
	getent group
}

metadata_users_passwd() {
	getent passwd
}

write_metadata() {
	local cmd file i jobs=(
		metadata_kernel kernel.uname.txt
		metadata_packages_all packages.all.txt
		metadata_packages_manual packages.manual.txt
		metadata_packages_flatpak packages.flatpak.txt
		metadata_packages_snap packages.snap.txt
		metadata_services_enabled services.enabled.txt
		metadata_storage_blkid storage.blkid.txt
		metadata_storage_findmnt storage.findmnt.txt
		metadata_storage_lsblk storage.lsblk.txt
		metadata_users_group users.group.txt
		metadata_users_passwd users.passwd.txt
	)

	for ((i = 0; i < ${#jobs[@]}; i += 2)); do
		cmd=${jobs[i]}
		file="$METADATA_DIR/${jobs[i + 1]}"
		"$cmd" >"$file" || rm -f -- "$file"
	done
}

filter_rsync_output() {
	local line now last=0 \
		progress_re='[(]xfr#[0-9]+, (ir|to)-chk=[0-9]+/[0-9]+[)]'

	while IFS= read -r line || [[ $line ]]; do
		if [[ $line =~ $progress_re ]]; then
			now=$(date +%s)
			if ((now - last >= 30)) || [[ $line == *100%* ]]; then
				printf '%s\n' "$line"
				last=$now
			fi
		else
			printf '%s\n' "$line"
		fi
	done
}

run_rsync() {
	local status=() mirror_dir="$STORAGE_MNT/$MIRROR_SUBVOL"
	info "Starting rsync mirror: / -> $mirror_dir/"

	set +e
	rsync \
		--info=del1,progress2,stats2 \
		--checksum \
		--archive \
		--hard-links \
		--acls \
		--xattrs \
		--one-file-system \
		--delete-delay \
		--delete-excluded \
		--numeric-ids \
		--fuzzy \
		--exclude-from="$RSYNC_EXCLUDE" \
		--human-readable \
		/ "$mirror_dir/" 2>&1 |
		stdbuf -o0 tr '\r' '\n' |
		filter_rsync_output 1>&2
	status=("${PIPESTATUS[@]}")
	set -e

	((status[2] == 0)) || return "${status[2]}"
	((status[1] == 0)) || return "${status[1]}"
	# exit 24 is "some files vanished before transfer,"  benign on a live root.
	((status[0] == 0 || status[0] == 24)) || return "${status[0]}"
}

run_btrbk() {
	info 'Running btrbk snapshot/prune'
	btrbk -c "$BTRBK_CONF" run 1>&2
}

main() {
	(($# <= 1)) || fatal "Too many arguments: $*"

	local ignore_cadence=0
	case ${1:-} in
	--now) ignore_cadence=1 ;;
	--init | '') ;;
	*) fatal "Unknown argument: $1" ;;
	esac

	load_config
	check_config

	if ((ignore_cadence == 0)) && ! is_due; then
		info "Not due---last successful backup was less than ${MIN_INTERVAL_DAYS} days ago. Pass \`--now\` to run anyway."
		exit 0
	fi

	acquire_lock
	install -m 700 -d "$STATE_DIR" "$METADATA_DIR"
	check_mounts

	if [[ ${1:-} == '--init' ]]; then
		info 'Initialized layout only'
		exit 0
	fi

	write_metadata
	run_rsync
	run_btrbk

	date --iso-8601=seconds >"$LAST_SUCCESS"

	info 'Backup completed successfully'
}

main "$@"
