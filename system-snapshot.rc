# Backup Btrfs top-level volume mount point.
STORAGE_MNT=/mnt/storage

# Backup-side mirror subvolume path, relative to STORAGE_MNT.
MIRROR_SUBVOL='@mirror'

# btrbk snapshot destination, relative to STORAGE_MNT.
SNAPSHOT_DIR='@backups/local/system-snapshots'

# Optional btrbk snapshot basename. Leave unset to use the short hostname.
# btrbk always stores snapshots as <basename>.<timestamp>.
#SNAPSHOT_NAME=''

# Config files.
CONFIG_DIR='/etc/system-snapshot'
BTRBK_CONF="$CONFIG_DIR/btrbk.conf"
RSYNC_EXCLUDE="$CONFIG_DIR/rsync.exclude"

# Persistent state on the live root.
STATE_DIR='/var/lib/system-snapshot'
LAST_SUCCESS="$STATE_DIR/last-success"
METADATA_DIR="$STATE_DIR/metadata"

# Timer fires twice daily; real backups run after this many days.
MIN_INTERVAL_DAYS=30
