# /etc/system-snapshot/config

# Backup data lives on the HDD-backed /var/backups filesystem.
BASE='/var/backups/local/system'
MIRROR="$BASE/mirror"
SNAPSHOTS="$BASE/snapshots"
METADATA="$BASE/metadata"

# Config files.
CONFIG_DIR='/etc/system-snapshot'
RSYNC_EXCLUDE="$CONFIG_DIR/rsync.exclude"
BTRBK_CONFIG="$CONFIG_DIR/btrbk.conf"

# Persistent state.
STATE_DIR='/var/lib/system-snapshot'
LAST_SUCCESS="$STATE_DIR/last-success"

# Runtime lock. Prevent concurrent runs.
LOCK='/run/system-snapshot.lock'

# Scheduling policy. The timer retries periodically, but the script only runs
# a real backup after this many days since the last successful backup.
# A manual forced run updates LAST_SUCCESS too, so it resets the next automatic run.
MIN_BACKUP_INTERVAL_DAYS=30

# If the backup reaches this age, run even if the idle check is not perfect.
# Set to 0 to never bypass the idle check.
MAX_BACKUP_AGE_DAYS=45

# Idle policy. The script uses the 1-minute load average from /proc/loadavg.
# On the Ryzen 9 9950X, `nproc` normally reports 32 logical CPUs.
# MAX_START_LOAD=4 means roughly "start only when the machine has about
# 28 logical CPUs worth of headroom," but load average is not exact CPU usage.
MAX_START_LOAD=4
