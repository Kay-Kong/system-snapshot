# /etc/system-snapshot/config

# Backup data lives on the HDD-backed /var/backups filesystem.
BASE='/var/backups/local/system'
MIRROR="$BASE/mirror"
SNAPSHOTS="$BASE/snapshots"

# Config files.
CONFIG_DIR='/etc/system-snapshot'
BTRBK_CONFIG_FILE="$CONFIG_DIR/btrbk.conf"
RSYNC_EXCLUDE_FILE="$CONFIG_DIR/rsync.exclude"

# Persistent state on the live root.
STATE_DIR='/var/lib/system-snapshot'
LAST_SUCCESS_FILE="$STATE_DIR/last-success"
LIVE_METADATA_DIR="$STATE_DIR/metadata"

# Runtime lock. Prevent concurrent runs.
LOCK='/run/system-snapshot.lock'

# Scheduling policy. The timer fires twice daily, but the script only runs
# a real backup after this many days since the last successful backup.
# A manual forced run updates LAST_SUCCESS_FILE too, so it resets the next automatic run.
MIN_BACKUP_INTERVAL_DAYS=30
