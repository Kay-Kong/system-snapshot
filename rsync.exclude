# /etc/system-snapshot/rsync.exclude

# Virtual/runtime filesystems.
/dev/**
/proc/**
/run/**
/sys/**
/tmp/**

# Mount points / removable / temporary mount locations.
/cdrom/**
/media/**
/mnt/**

# Filesystem internals.
/boot/lost+found/
/lost+found/

# Already on the HDD, do not back up into the system mirror.
/var/backups/**
/var/crash/**

# System-level rebuildable caches and bulky transient state.
# These directory patterns exclude the directory itself and all contents.
/var/cache/
/var/lib/apt/lists/
/var/lib/snapd/cache/
/var/lib/systemd/coredump/
/var/tmp/

# User caches and generated tool state.
# .cache covers pip, uv, torch, huggingface, npm/yarn XDG caches, Zed caches,
# browser caches, and many other application caches.
/home/**/.cache/
/home/**/.local/share/Trash/
/root/**/.cache/

# Remote editor/agent servers.
/home/**/.antigravity/
/home/**/.cache/code-server/
/home/**/.continue/server/
/home/**/.cursor-server/
/home/**/.kiro-server/
/home/**/.local/share/code-server/
/home/**/.trae-server/
/home/**/.vscode-server*/
/home/**/.windsurf-server/
/home/**/.zed_server/

# AI coding agent disposable state.
# Exclude bulky session/cache/log/checkpoint state.
/home/**/.cache/Antigravity/
/home/**/.cache/Google/Antigravity/
/home/**/.claude/backups/
/home/**/.claude/debug/
/home/**/.claude/file-history/
/home/**/.claude/image-cache/
/home/**/.claude/paste-cache/
/home/**/.claude/plans/
/home/**/.claude/projects/*/*/tool-results/
/home/**/.claude/session-env/
/home/**/.claude/shell-snapshots/
/home/**/.claude/tasks/
/home/**/.claude/todos/
/home/**/.codex/cache/
/home/**/.codex/logs/
/home/**/.codex/sessions/
/home/**/.config/Antigravity/CachedData/
/home/**/.config/Antigravity/Code Cache/
/home/**/.config/Antigravity/Crashpad/
/home/**/.config/Antigravity/GPUCache/
/home/**/.config/Antigravity/logs/
/home/**/.gemini/cache/
/home/**/.gemini/tmp/

# Language/package manager caches outside ~/.cache.
/home/**/.cargo/git/
/home/**/.cargo/registry/
/home/**/.conda/pkgs/
/home/**/.gradle/caches/
/home/**/.gradle/daemon/
/home/**/.ivy2/cache/
/home/**/.julia/compiled/
/home/**/.julia/logs/
/home/**/.m2/repository/
/home/**/.mamba/pkgs/
/home/**/.micromamba/pkgs/
/home/**/.node-gyp/
/home/**/.npm/
/home/**/.pnpm-store/
/home/**/.rustup/downloads/
/home/**/.rustup/tmp/
/home/**/.sbt/
/home/**/.yarn/cache/
/home/**/anaconda3/pkgs/
/home/**/go/pkg/mod/
/home/**/go/pkg/sumdb/
/home/**/miniconda3/pkgs/
/root/.npm/
/root/.nv/ComputeCache/

# ML/GPU/generated caches outside ~/.cache.
/home/**/.ccache/
/home/**/.nv/ComputeCache/
/home/**/.triton/

# Project-local dependency/build state.
/home/**/*.pyc
/home/**/.ipynb_checkpoints/
/home/**/.mypy_cache/
/home/**/.nox/
/home/**/.pixi/
/home/**/.pytest_cache/
/home/**/.ruff_cache/
/home/**/.terraform/
/home/**/.tox/
/home/**/.venv/
/home/**/__pycache__/
/home/**/node_modules/
/home/**/venv/

# Optional huge/volatile stores.
/var/lib/containers/**
/var/lib/docker/**
/var/lib/libvirt/images/**
