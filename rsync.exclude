# Virtual/runtime filesystems.
/dev/**
/proc/**
/run/**
/sys/**
/tmp/**

# Mount points / removable / temporary mount locations.
/cdrom/**
/media/**
/mnt/**

# Filesystem internals.
/boot/lost+found/
/lost+found/

# Swap file.
/swap.img

# Already on the HDD, do not back up into the system mirror.
/var/backups/**
/var/crash/**

# System-level rebuildable caches and bulky transient state.
# These directory patterns exclude the directory itself and all contents.
/var/cache/
/var/lib/apt/lists/
/var/lib/snapd/cache/
/var/lib/systemd/coredump/
/var/tmp/

# User caches and generated tool state.
# .cache covers pip, uv, torch, huggingface, npm/yarn XDG caches, Zed caches,
# browser caches, and many other application caches.
**/.cache/
**/.local/share/Trash/

# Remote editor/agent servers.
/home/**/.antigravity/
#/home/**/.cache/code-server/
/home/**/.continue/server/
/home/**/.cursor-server/
/home/**/.kiro-server/
/home/**/.local/share/code-server/
/home/**/.trae-server/
/home/**/.vscode-server*/
/home/**/.windsurf-server/
/home/**/.zed_server/

# AI coding agent disposable state.
# Exclude bulky session/cache/log/checkpoint state.
#**/.cache/Antigravity/
#**/.cache/Google/Antigravity/
**/.claude/backups/
**/.claude/debug/
**/.claude/file-history/
**/.claude/image-cache/
**/.claude/paste-cache/
**/.claude/plans/
**/.claude/projects/*/*/tool-results/
**/.claude/session-env/
**/.claude/shell-snapshots/
**/.claude/tasks/
**/.claude/todos/
**/.codex/cache/
**/.codex/logs/
**/.codex/sessions/
**/.config/Antigravity/CachedData/
**/.config/Antigravity/Code Cache/
**/.config/Antigravity/Crashpad/
**/.config/Antigravity/GPUCache/
**/.config/Antigravity/logs/
**/.gemini/cache/
**/.gemini/tmp/

# Language/package manager caches outside ~/.cache.
**/.cargo/git/
**/.cargo/registry/
**/.conda/pkgs/
**/.gradle/caches/
**/.gradle/daemon/
**/.ivy2/cache/
**/.julia/compiled/
**/.julia/logs/
**/.m2/repository/
**/.mamba/pkgs/
**/.micromamba/pkgs/
**/.node-gyp/
**/.npm/
**/.pnpm-store/
**/.rustup/downloads/
**/.rustup/tmp/
**/.sbt/
**/.yarn/cache/
**/anaconda3/pkgs/
**/go/pkg/mod/
**/go/pkg/sumdb/
**/miniconda3/pkgs/

# ML/GPU/generated caches outside ~/.cache.
**/.ccache/
**/.nv/ComputeCache/
**/.triton/

# Project-local dependency/build state.
**/*.pyc
**/*.pyo
**/.ipynb_checkpoints/
**/.mypy_cache/
**/.nox/
**/.pixi/
**/.pytest_cache/
**/.ruff_cache/
**/.terraform/
**/.tox/
**/.venv/
**/__pycache__/
**/node_modules/
**/venv/

# Optional huge/volatile stores.
/var/lib/containers/**
/var/lib/docker/**
/var/lib/libvirt/images/**
