#!/usr/bin/env bash
CONFIG='/etc/system-snapshot/system-snapshot.rc'

set -euo pipefail

fatal() {
	printf '[ERROR] %s\n' "$*" >&2
	exit 1
}

[[ -r $CONFIG ]] || fatal "Missing config: $CONFIG"
. "$CONFIG"

[[ ${BACKUP_MNT:-} ]] || fatal "BACKUP_MNT not set in $CONFIG"
[[ $BACKUP_MNT == /* ]] || fatal "BACKUP_MNT must be absolute: $BACKUP_MNT"
[[ $BACKUP_MNT != '/' ]] || fatal 'BACKUP_MNT cannot be /'
[[ $BACKUP_MNT != *'..'* ]] || fatal "BACKUP_MNT cannot contain '..': $BACKUP_MNT"

findmnt -q --mountpoint "$BACKUP_MNT" ||
	fatal "$BACKUP_MNT is not mounted"
